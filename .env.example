# Billology — example environment configuration (no real secrets).
# Copy the relevant section into backend/.env and mobile/.env and fill in
# real values. Per-package examples: backend/.env.example, mobile/.env.example.
#
# The core extract -> verify -> explain flow works with NONE of the backend
# keys set (deterministic fallbacks); keys upgrade extraction/explanations and
# enable saving.

# ============================================================================
# Backend (FastAPI)  ->  backend/.env
# ============================================================================

# --- Supabase (Postgres + pgvector + Storage) --------------------------------
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Service-role key. SUPABASE_KEY is also accepted as an alias.
SUPABASE_SERVICE_KEY=YOUR-SERVICE-KEY
# Anon (publishable) key — safe to expose to browsers; used with the caller's
# JWT so user-facing DB access runs under Postgres RLS as that user.
SUPABASE_ANON_KEY=YOUR-ANON-KEY
# HS256 secret that signs Supabase Auth JWTs (dashboard -> Project Settings ->
# API -> JWT Secret) — used to verify the access token the client sends.
SUPABASE_JWT_SECRET=YOUR-JWT-SECRET
SUPABASE_BUCKET=bills

# --- LLM provider ------------------------------------------------------------
# "groq" (cloud, default) or "ollama" (local inference).
LLM_PROVIDER=groq

# Groq
GROQ_API_KEY=YOUR-GROQ-KEY
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama (only used when LLM_PROVIDER=ollama)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# --- Vision extraction (v2) --------------------------------------------------
# Bill images are transcribed by a multimodal model. Set VISION_EXTRACTION=false
# to force the local deterministic OCR pipeline (also the automatic fallback).
VISION_EXTRACTION=true
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
OLLAMA_VISION_MODEL=llama3.2-vision

# --- Embeddings (fastembed, local) -------------------------------------------
# Dimension MUST match the pgvector column (384).
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384

# --- API hardening -------------------------------------------------------------
# Comma-separated browser origins allowed by CORS ("*" keeps the bundled web
# demo working from any host; set explicit origins in production).
ALLOWED_ORIGINS=*
# Include exception details in 500 responses (local debugging only).
DEBUG_ERRORS=false

# ============================================================================
# Mobile (Expo / React Native)  ->  mobile/.env
# ============================================================================

# Backend base URL (deployed URL, or your LAN IP for local dev).
EXPO_PUBLIC_API_BASE=https://billology.onrender.com
# Supabase (Google sign-in). The anon key is safe to ship in the app.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
