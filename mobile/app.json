{
  "expo": {
    "name": "Billology",
    "slug": "billology",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "billology",
    "icon": "./assets/icon.png",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.srikeerthan.billology"
    },
    "android": {
      "package": "com.srikeerthan.billology",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D2B28"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Billology to use the camera to capture your bills.",
          "recordAudioAndroid": false
        }
      ],
      "expo-image-picker",
      "expo-document-picker",
      "expo-font",
      "expo-web-browser",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#0D2B28"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "f7fb71e8-7838-409c-b3a9-87aab700723e"
      }
    }
  }
}
