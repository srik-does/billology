SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_KEY=YOUR-SERVICE-KEY
SUPABASE_BUCKET=bills
GROQ_API_KEY=YOUR-GROQ-KEY
GROQ_MODEL=llama-3.3-70b-versatile
# v2 vision extraction: bill images are transcribed by this multimodal model.
# Set VISION_EXTRACTION=false to force the local deterministic OCR pipeline.
GROQ_VISION_MODEL=meta-llama/llama-4-maverick-17b-128e-instruct
VISION_EXTRACTION=true
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384
