# EditorConfig — consistent whitespace/encoding across editors.
# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Python — 4 spaces, 100-col soft limit (matches pyproject.toml ruff config).
[*.py]
indent_size = 4
max_line_length = 100

# JS/TS/JSON/YAML for the Expo client and CI config — 2 spaces (default above).
[*.{js,jsx,ts,tsx,json,yml,yaml}]
indent_size = 2

# Markdown — keep trailing whitespace (two spaces = hard line break).
[*.md]
trim_trailing_whitespace = false

# Windows batch files require CRLF.
[*.{bat,cmd}]
end_of_line = crlf

# Makefiles require real tabs.
[Makefile]
indent_style = tab
